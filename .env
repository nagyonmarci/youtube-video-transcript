POSTGRES_USER=ytuser
POSTGRES_PASSWORD=ytpassword
POSTGRES_DB=transcripts
DATABASE_URL=postgresql://ytuser:ytpassword@db:5432/transcripts
DEV_MODE=true

# VPN Configuration (Gluetun)
# Get your credentials from your VPN provider
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
# For Wireguard:
WIREGUARD_PRIVATE_KEY=your_private_key
WIREGUARD_ADDRESSES=10.0.0.2/32
# SERVER_COUNTRIES, SERVER_REGIONS, etc. depending on provider
# For custom wireguard:
VPN_ENDPOINT_IP=your_vpn_ip
VPN_ENDPOINT_PORT=51820
WIREGUARD_PUBLIC_KEY=your_public_key
