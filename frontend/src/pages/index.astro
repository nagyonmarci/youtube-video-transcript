---
import App from '../App.jsx';
---

<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YouTube Transcript Downloader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <App client:only="react" />
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0f0f0f;
    --bg2: #1a1a1a;
    --bg3: #242424;
    --border: #333;
    --text: #e0e0e0;
    --text2: #aaa;
    --primary: #ff4444;
    --primary-dim: rgba(255,68,68,0.15);
    --green: #4caf50;
    --yellow: #ffc107;
    --red: #f44336;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  button {
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--bg3);
    color: var(--text);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s;
  }
  button:hover { background: var(--bg2); border-color: #555; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }
  button.primary { background: var(--primary); border-color: var(--primary); color: #fff; font-weight: 600; }
  button.primary:hover { background: #cc3333; }
  button.danger { background: rgba(244,67,54,0.2); border-color: rgba(244,67,54,0.4); color: #f88; }
  button.danger:hover { background: rgba(244,67,54,0.35); }

  input, textarea, select {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    font-size: 0.85rem;
    outline: none;
    width: 100%;
  }
  input:focus, textarea:focus { border-color: #555; }

  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-done { background: rgba(76,175,80,0.2); color: #6fcf73; }
  .badge-pending { background: rgba(255,193,7,0.2); color: #ffc107; }
  .badge-processing { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-queued { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-running { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-paused { background: rgba(255,193,7,0.2); color: #ffc107; }
  .badge-cancelled { background: rgba(158,158,158,0.2); color: #bbb; }
  .badge-no_transcript { background: rgba(158,158,158,0.2); color: #bbb; }
  .badge-error { background: rgba(244,67,54,0.2); color: #f88; }

  .app-layout {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .app-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .header-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .main-nav button {
    padding: 0.3rem 0.7rem;
    font-size: 0.82rem;
  }
  .main-nav button.active {
    background: var(--primary-dim);
    border-color: var(--primary);
    color: #fff;
  }
  .header-status-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .badge-whisper {
    background: rgba(156,39,176,0.2);
    color: #ce93d8;
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .whisper-btn {
    background: rgba(156,39,176,0.2);
    border-color: rgba(156,39,176,0.4);
    color: #ce93d8;
    font-weight: 600;
  }
  .whisper-btn:hover {
    background: rgba(156,39,176,0.35);
  }

  .app-content {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .view-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.75rem;
  }
  .view-header h2 {
    font-size: 1rem;
    font-weight: 700;
  }
  .view-header p {
    color: var(--text2);
    font-size: 0.82rem;
    margin-top: 0.15rem;
  }

  /* --- Daily Updates --- */
  .daily-page {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .daily-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .daily-controls input[type="date"],
  .daily-controls select {
    width: auto;
    min-width: 150px;
  }
  .daily-groups {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .daily-channel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .daily-channel-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .daily-channel-header h3 {
    font-size: 0.95rem;
  }
  .daily-channel-header span {
    color: var(--text2);
    font-size: 0.8rem;
  }
  .daily-video-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .daily-video-card {
    display: flex;
    justify-content: space-between;
    gap: 0.85rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem;
    min-width: 0;
  }
  .daily-video-main {
    min-width: 0;
    flex: 1;
  }
  .daily-video-title {
    color: #64b5f6;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    line-height: 1.35;
  }
  .daily-video-title:hover { text-decoration: underline; }
  .daily-video-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    color: var(--text2);
    font-size: 0.75rem;
    margin-top: 0.45rem;
  }
  .daily-summary {
    margin-top: 0.65rem;
    color: #ddd;
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .daily-muted {
    color: var(--text2);
    font-style: italic;
  }
  .topic-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.65rem;
  }
  .topic-row span {
    border: 1px solid rgba(100,181,246,0.35);
    color: #90caf9;
    border-radius: 999px;
    padding: 0.15rem 0.45rem;
    font-size: 0.72rem;
  }
  .daily-list {
    margin: 0.65rem 0 0;
    padding-left: 1.1rem;
    color: #ddd;
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .daily-video-actions {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 96px;
    align-self: flex-start;
  }
  .daily-video-actions button {
    font-size: 0.75rem;
    padding: 0.25rem 0.45rem;
  }

  /* --- Admin Dashboard --- */
  .admin-dashboard {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(130px, 1fr));
    gap: 0.75rem;
  }
  .metric-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem;
  }
  .metric-card span {
    display: block;
    color: var(--text2);
    font-size: 0.78rem;
    margin-bottom: 0.3rem;
  }
  .metric-card strong {
    font-size: 1.35rem;
  }
  .admin-section {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .admin-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }
  .admin-section-header h3 {
    font-size: 0.95rem;
  }
  .admin-section-header span {
    color: var(--text2);
    font-size: 0.8rem;
  }
  .admin-section-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .process-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .process-line {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem;
    min-width: 0;
  }
  .process-line h4 {
    font-size: 0.86rem;
    margin-bottom: 0.25rem;
  }
  .process-line p {
    color: var(--text2);
    font-size: 0.78rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .job-progress {
    width: 100%;
    height: 0.45rem;
    margin-top: 0.35rem;
    accent-color: var(--accent);
  }
  .job-progress-text {
    color: var(--text2);
    font-size: 0.72rem;
    margin-top: 0.18rem;
  }
  .process-actions {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .schedule-form {
    display: flex;
    align-items: flex-end;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .schedule-form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--text2);
    font-size: 0.78rem;
  }
  .schedule-form input,
  .schedule-form select {
    width: 190px;
  }
  .job-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg2);
  }
  .job-table {
    width: 100%;
    min-width: 960px;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: 0.82rem;
  }
  .job-table th {
    color: var(--text2);
    font-weight: 600;
    text-align: left;
    padding: 0.55rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .job-table td {
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    vertical-align: middle;
  }
  .job-table th:nth-child(1), .job-table td:nth-child(1) { width: 9%; }
  .job-table th:nth-child(2), .job-table td:nth-child(2) { width: 43%; }
  .job-table th:nth-child(3), .job-table td:nth-child(3) { width: 12%; }
  .job-table th:nth-child(4), .job-table td:nth-child(4) { width: 13%; }
  .job-table th:nth-child(5), .job-table td:nth-child(5) { width: 23%; }
  .job-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .job-error {
    color: #f88;
    font-size: 0.74rem;
    margin-top: 0.2rem;
    overflow-wrap: anywhere;
  }
  .job-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .job-actions button {
    font-size: 0.72rem;
    padding: 0.18rem 0.42rem;
  }

  /* --- Top Actions (3 cards in a row, always equal width) --- */
  .top-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    align-items: flex-start;
  }
  .top-actions .status-msg {
    grid-column: 1 / -1;
  }
  .card-title {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    color: var(--text2);
  }

  .status-msg {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.82rem;
    width: 100%;
  }
  .status-success { background: rgba(76,175,80,0.2); color: #6fcf73; }
  .status-error { background: rgba(244,67,54,0.2); color: #f88; }

  /* --- Channel Grid --- */
  .channel-section {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .channel-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .channel-search {
    width: 160px;
  }
  .channel-sort {
    width: 150px;
  }
  .channel-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .channel-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    min-width: 140px;
    max-width: 220px;
    transition: border-color 0.15s, background 0.15s;
  }
  .channel-card:hover { border-color: #555; }
  .channel-card-selected {
    background: var(--primary-dim);
    border-color: var(--primary);
  }
  .channel-card-name {
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .channel-card-meta {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .channel-card-actions {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }
  .channel-card-actions button {
    font-size: 0.72rem;
    padding: 0.15rem 0.4rem;
  }

  /* --- Video Section --- */
  .video-section {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .video-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .video-title {
    font-size: 1rem;
    font-weight: 600;
  }
  .video-search {
    width: 250px;
    max-width: 100%;
  }
  .video-empty {
    text-align: center;
    padding: 2rem;
    color: #666;
  }
  .table-scroll {
    overflow-x: auto;
  }
  .video-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  .video-table {
    table-layout: fixed;
  }
  .video-table th {
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-weight: 600;
    color: var(--text2);
    white-space: nowrap;
    cursor: pointer;
    user-select: none;
    border-bottom: 1px solid var(--border);
  }
  .video-table td {
    padding: 0.5rem 0.75rem;
    vertical-align: middle;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .video-table td:first-child {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .video-table .clickable-row { cursor: pointer; }
  .video-table .clickable-row:hover { background: rgba(255,255,255,0.04); }
  .video-link {
    color: #64b5f6;
    text-decoration: none;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .video-link:hover { text-decoration: underline; }
  .btn-sm {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
  }

  /* --- Channel Admin --- */
  .admin-panel {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .admin-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .admin-panel-header h2 {
    font-size: 1rem;
    font-weight: 700;
  }
  .admin-panel-header p {
    color: var(--text2);
    font-size: 0.82rem;
    margin-top: 0.15rem;
  }
  .admin-toolbar {
    margin-bottom: 0.75rem;
    max-width: 420px;
  }
  .admin-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg2);
  }
  .admin-table {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: 0.82rem;
  }
  .admin-table th {
    color: var(--text2);
    font-weight: 600;
    text-align: left;
    padding: 0.55rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .admin-table td {
    padding: 0.45rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    vertical-align: middle;
  }
  .admin-table th:nth-child(1), .admin-table td:nth-child(1) { width: 18%; }
  .admin-table th:nth-child(2), .admin-table td:nth-child(2) { width: 30%; }
  .admin-table th:nth-child(3), .admin-table td:nth-child(3) { width: 18%; }
  .admin-table th:nth-child(4), .admin-table td:nth-child(4) { width: 13%; }
  .admin-table th:nth-child(5), .admin-table td:nth-child(5) { width: 7%; }
  .admin-table th:nth-child(6), .admin-table td:nth-child(6) { width: 14%; }
  .admin-table input,
  .admin-table select {
    font-size: 0.8rem;
    padding: 0.3rem 0.45rem;
  }
  .admin-count {
    color: var(--text2);
    text-align: right;
  }
  .admin-row-actions {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .admin-row-actions button {
    font-size: 0.72rem;
    padding: 0.18rem 0.45rem;
  }
  .admin-empty {
    color: var(--text2);
    text-align: center;
    padding: 1rem;
  }

  /* --- Pagination --- */
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
    margin-top: 0.5rem;
  }
  .page-info {
    font-size: 0.85rem;
    color: var(--text2);
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .app-content { padding: 0.5rem; }
    .app-header { align-items: flex-start; flex-wrap: wrap; }
    .header-status { margin-left: 0; width: 100%; }
    .top-actions { grid-template-columns: 1fr; }
    .metric-grid, .process-panel { grid-template-columns: 1fr; }
    .daily-video-list { grid-template-columns: 1fr; }
    .daily-video-card { flex-direction: column; }
    .daily-video-actions { flex-direction: row; flex-wrap: wrap; }
    .channel-card { min-width: 100px; max-width: 160px; }
    .video-header { flex-direction: column; align-items: flex-start; }
    .video-search { width: 100%; }
    .app-header h1 { font-size: 0.95rem; }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .channel-card { max-width: 180px; }
  }
</style>
