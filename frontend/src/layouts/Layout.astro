---
const { title = 'YouTube Transcript Downloader' } = Astro.props;
---

<!DOCTYPE html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      const t = localStorage.getItem('yt_theme');
      if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #1e1e2e;
    --bg2: #181825;
    --bg3: #313244;
    --border: #45475a;
    --text: #cdd6f4;
    --text2: #a6adc8;
    --primary: #f38ba8;
    --primary-dim: rgba(243,139,168,0.15);
    --green: #a6e3a1;
    --yellow: #f9e2af;
    --red: #f38ba8;
  }

  [data-theme="light"] {
    --bg: #eff1f5;
    --bg2: #e6e9ef;
    --bg3: #dce0e8;
    --border: #ccd0da;
    --text: #4c4f69;
    --text2: #6c6f85;
    --primary: #d20f39;
    --primary-dim: rgba(210,15,57,0.12);
    --green: #40a02b;
    --yellow: #df8e1d;
    --red: #d20f39;
  }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
  }

  button {
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--bg3);
    color: var(--text);
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    transition: background 0.15s, border-color 0.15s;
  }
  button:hover { background: var(--bg2); border-color: #555; }
  button:disabled { opacity: 0.5; cursor: not-allowed; }
  button.primary { background: var(--primary); border-color: var(--primary); color: #fff; font-weight: 600; }
  button.primary:hover { background: #cc3333; }
  button.danger { background: rgba(244,67,54,0.2); border-color: rgba(244,67,54,0.4); color: #f88; }
  button.danger:hover { background: rgba(244,67,54,0.35); }

  input, textarea, select {
    background: var(--bg3);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    font-size: 0.85rem;
    outline: none;
    width: 100%;
  }
  input:focus, textarea:focus { border-color: #555; }

  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .badge-done { background: rgba(76,175,80,0.2); color: #6fcf73; }
  .badge-pending { background: rgba(255,193,7,0.2); color: #ffc107; }
  .badge-processing { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-queued { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-running { background: rgba(33,150,243,0.2); color: #64b5f6; }
  .badge-paused { background: rgba(255,193,7,0.2); color: #ffc107; }
  .badge-cancelled { background: rgba(158,158,158,0.2); color: #bbb; }
  .badge-no_transcript { background: rgba(158,158,158,0.2); color: #bbb; }
  .badge-error { background: rgba(244,67,54,0.2); color: #f88; }

  .app-layout {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .app-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .header-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .main-nav button,
  .main-nav a {
    padding: 0.3rem 0.7rem;
    font-size: 0.82rem;
    cursor: pointer;
    border: 1px solid var(--border);
    background: var(--bg3);
    color: var(--text);
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .main-nav button:hover,
  .main-nav a:hover { background: var(--bg2); border-color: #555; }
  .main-nav button.active,
  .main-nav a.active {
    background: var(--primary-dim);
    border-color: var(--primary);
    color: #fff;
  }
  .header-status-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .status-chip {
    display: inline-block;
    max-width: 160px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: middle;
  }
  .status-chip-video {
    max-width: 120px;
    cursor: default;
  }
  .badge-whisper {
    background: rgba(156,39,176,0.2);
    color: #ce93d8;
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .whisper-btn {
    background: rgba(156,39,176,0.2);
    border-color: rgba(156,39,176,0.4);
    color: #ce93d8;
    font-weight: 600;
  }
  .whisper-btn:hover {
    background: rgba(156,39,176,0.35);
  }

  .app-content {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .scroll-top-button {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 2100;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border-radius: 999px;
    border-color: rgba(255,68,68,0.5);
    background: rgba(36,36,36,0.94);
    color: #fff;
    font-size: 1.35rem;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 8px 20px rgba(0,0,0,0.35);
  }
  .scroll-top-button:hover {
    background: var(--primary);
    border-color: var(--primary);
  }

  .view-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.75rem;
  }
  .view-header h2 {
    font-size: 1rem;
    font-weight: 700;
  }
  .view-header p {
    color: var(--text2);
    font-size: 0.82rem;
    margin-top: 0.15rem;
  }

  /* --- Daily Updates --- */
  .daily-page {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .daily-controls {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .daily-controls input[type="date"],
  .daily-controls select {
    width: auto;
    min-width: 150px;
  }
  .daily-groups {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .daily-channel {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .daily-channel-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .daily-channel-header h3 {
    font-size: 0.95rem;
  }
  .daily-channel-header span {
    color: var(--text2);
    font-size: 0.8rem;
  }
  .daily-video-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .daily-video-card {
    display: flex;
    justify-content: space-between;
    gap: 0.85rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem;
    min-width: 0;
  }
  .daily-video-main {
    min-width: 0;
    flex: 1;
  }
  .daily-video-title {
    color: #64b5f6;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    line-height: 1.35;
  }
  .daily-video-title:hover { text-decoration: underline; }
  .daily-video-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    color: var(--text2);
    font-size: 0.75rem;
    margin-top: 0.45rem;
  }
  .daily-summary {
    margin-top: 0.65rem;
    color: #ddd;
    font-size: 0.86rem;
    line-height: 1.55;
  }
  .daily-muted {
    color: var(--text2);
    font-style: italic;
  }
  .topic-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.65rem;
  }
  .topic-row span {
    border: 1px solid rgba(100,181,246,0.35);
    color: #90caf9;
    border-radius: 999px;
    padding: 0.15rem 0.45rem;
    font-size: 0.72rem;
  }
  .daily-list {
    margin: 0.65rem 0 0;
    padding-left: 1.1rem;
    color: #ddd;
    font-size: 0.82rem;
    line-height: 1.5;
  }
  .daily-video-actions {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 96px;
    align-self: flex-start;
  }
  .daily-video-actions button {
    font-size: 0.75rem;
    padding: 0.25rem 0.45rem;
  }

  /* --- Admin Dashboard --- */
  .admin-dashboard {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(130px, 1fr));
    gap: 0.75rem;
  }
  .metric-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.85rem;
  }
  .metric-card span {
    display: block;
    color: var(--text2);
    font-size: 0.78rem;
    margin-bottom: 0.3rem;
  }
  .metric-card strong {
    font-size: 1.35rem;
  }
  .admin-section {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .admin-section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.6rem;
  }
  .admin-section-header h3 {
    font-size: 0.95rem;
  }
  .admin-section-header span {
    color: var(--text2);
    font-size: 0.8rem;
  }
  .admin-section-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .process-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(220px, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .process-line {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem;
    min-width: 0;
  }
  .process-line h4 {
    font-size: 0.86rem;
    margin-bottom: 0.25rem;
  }
  .process-line p {
    color: var(--text2);
    font-size: 0.78rem;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .job-progress {
    width: 100%;
    height: 0.45rem;
    margin-top: 0.35rem;
    accent-color: var(--accent);
  }
  .job-progress-text {
    color: var(--text2);
    font-size: 0.72rem;
    margin-top: 0.18rem;
  }
  .process-actions {
    display: flex;
    align-items: flex-start;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .ai-status-panel {
    display: flex;
    justify-content: space-between;
    gap: 0.85rem;
    align-items: flex-start;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-left: 4px solid var(--accent);
    border-radius: 8px;
    padding: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .ai-status-running { border-left-color: #64b5f6; }
  .ai-status-manual { border-left-color: #ffb74d; }
  .ai-status-paused { border-left-color: #f88; }
  .ai-status-queued,
  .ai-status-waiting { border-left-color: #b39ddb; }
  .ai-status-idle { border-left-color: #6fcf73; }
  .ai-status-main {
    min-width: 0;
  }
  .ai-status-kicker {
    color: var(--text2);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    margin-bottom: 0.2rem;
  }
  .ai-status-main strong {
    display: block;
    font-size: 0.92rem;
    margin-bottom: 0.25rem;
  }
  .ai-status-main p {
    color: var(--text2);
    font-size: 0.82rem;
    line-height: 1.45;
    max-width: 56rem;
  }
  .ai-status-side {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .ai-status-pill {
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text2);
    font-size: 0.75rem;
    padding: 0.18rem 0.5rem;
    background: rgba(255,255,255,0.03);
    white-space: nowrap;
  }
  .resource-panel {
    display: grid;
    grid-template-columns: repeat(3, minmax(180px, 1fr));
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .resource-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem;
    min-width: 0;
  }
  .resource-card span {
    display: block;
    color: var(--text2);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .resource-card strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }
  .resource-card p {
    color: var(--text2);
    font-size: 0.78rem;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }
  .resource-card small {
    display: block;
    color: var(--text2);
    font-size: 0.68rem;
    line-height: 1.35;
    margin-top: 0.35rem;
  }
  .schedule-form {
    display: flex;
    align-items: flex-end;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .schedule-form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--text2);
    font-size: 0.78rem;
  }
  .schedule-form input,
  .schedule-form select {
    width: 190px;
  }
  .settings-form {
    display: grid;
    grid-template-columns: repeat(4, minmax(170px, 1fr));
    gap: 0.65rem;
    align-items: end;
  }
  .settings-form label {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    color: var(--text2);
    font-size: 0.78rem;
    min-width: 0;
  }
  .settings-check {
    flex-direction: row !important;
    align-items: center;
    color: var(--text);
    min-height: 2.25rem;
  }
  .settings-check input {
    width: auto;
  }
  .settings-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .job-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg2);
  }
  .job-table {
    width: 100%;
    min-width: 960px;
    border-collapse: collapse;
    table-layout: fixed;
    font-size: 0.82rem;
  }
  .job-table th {
    color: var(--text2);
    font-weight: 600;
    text-align: left;
    padding: 0.55rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .job-table td {
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    vertical-align: middle;
  }
  .job-table th:nth-child(1), .job-table td:nth-child(1) { width: 9%; }
  .job-table th:nth-child(2), .job-table td:nth-child(2) { width: 43%; }
  .job-table th:nth-child(3), .job-table td:nth-child(3) { width: 12%; }
  .job-table th:nth-child(4), .job-table td:nth-child(4) { width: 13%; }
  .job-table th:nth-child(5), .job-table td:nth-child(5) { width: 23%; }
  .job-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .job-error {
    color: #f88;
    font-size: 0.74rem;
    margin-top: 0.2rem;
    overflow-wrap: anywhere;
  }
  .job-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .job-actions button {
    font-size: 0.72rem;
    padding: 0.18rem 0.42rem;
  }

  /* --- Top Actions (3 cards in a row, always equal width) --- */
  .top-actions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    align-items: flex-start;
  }
  .top-actions .status-msg {
    grid-column: 1 / -1;
  }
  .card-title {
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    color: var(--text2);
  }

  .status-msg {
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.82rem;
    width: 100%;
  }
  .status-success { background: rgba(76,175,80,0.2); color: #6fcf73; }
  .status-error { background: rgba(244,67,54,0.2); color: #f88; }

  /* --- Channel Grid --- */
  .channel-section {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .channel-section-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .channel-search {
    width: 160px;
  }
  .channel-sort {
    width: 150px;
  }
  .channel-topic-filter {
    width: 170px;
  }
  .channel-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .channel-topic-group {
    margin-top: 0.75rem;
  }
  .channel-topic-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .channel-topic-header h4 {
    font-size: 0.82rem;
    color: var(--text);
    margin: 0;
  }
  .channel-topic-header span {
    color: var(--text2);
    font-size: 0.72rem;
  }
  .channel-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    min-width: 140px;
    max-width: 220px;
    transition: border-color 0.15s, background 0.15s;
  }
  .channel-card:hover { border-color: #555; }
  .channel-card-selected {
    background: var(--primary-dim);
    border-color: var(--primary);
  }
  .channel-card-name {
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .channel-card-meta {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .channel-card-actions {
    display: flex;
    gap: 0.25rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }
  .channel-card-actions button {
    font-size: 0.72rem;
    padding: 0.15rem 0.4rem;
  }
  .channel-card-dragging {
    opacity: 0.45;
    cursor: grabbing;
  }
  .channel-card[draggable="true"] {
    cursor: grab;
  }
  .channel-card[draggable="true"]:active {
    cursor: grabbing;
  }
  .channel-drop-over {
    background: var(--primary-dim);
    border-radius: 8px;
    outline: 2px dashed var(--primary);
    outline-offset: 2px;
  }
  .channel-drop-hint {
    font-size: 0.78rem;
    color: var(--text2);
    font-style: italic;
    padding: 0.4rem 0.5rem;
    min-width: 120px;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
    border: 1px dashed var(--border);
    border-radius: 8px;
  }
  .channel-topic-label {
    font-size: 0.82rem;
    color: var(--text);
    margin: 0;
    cursor: text;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .channel-topic-label:hover {
    border-bottom-color: var(--border);
  }
  .channel-topic-edit-input {
    font-size: 0.82rem;
    font-weight: 600;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--primary);
    color: var(--text);
    padding: 0;
    width: auto;
    min-width: 60px;
    max-width: 220px;
    outline: none;
    border-radius: 0;
  }
  .channel-topic-label-muted {
    color: var(--text2);
    cursor: default;
  }
  .channel-topic-label-muted:hover {
    border-bottom-color: transparent;
  }
  .channel-topic-count {
    color: var(--text2);
    font-size: 0.72rem;
