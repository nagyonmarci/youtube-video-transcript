# PostgreSQL
POSTGRES_PASSWORD=directus

# Directus
DIRECTUS_SECRET=change-me-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin
DIRECTUS_ADMIN_TOKEN=admin-token-change-me

# Automatic channel refresh cron (default: daily at 2:00 AM)
REFRESH_CRON=0 2 * * *

# Whisper service
WHISPER_THREADS=4
WHISPER_LANGUAGE=auto
WHISPER_BATCH_CRON=0 3 * * *
WHISPER_BATCH_LIMIT=50
