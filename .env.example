POSTGRES_USER=ytuser
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=transcripts
DATABASE_URL=postgresql://ytuser:your_password_here@db:5432/transcripts
DEV_MODE=true

# VPN Configuration (Gluetun) - optional
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key
WIREGUARD_ADDRESSES=10.0.0.2/32
VPN_ENDPOINT_IP=your_vpn_ip
VPN_ENDPOINT_PORT=51820
WIREGUARD_PUBLIC_KEY=your_public_key
