# PostgreSQL
POSTGRES_PASSWORD=directus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=directus
POSTGRES_USER=directus

APP_API_TOKEN=replace-with-random-browser-proxy-token
APP_CORS_ORIGINS=http://yt.test,http://localhost:4321
APP_BASIC_AUTH_USER=admin
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
APP_BASIC_AUTH_HASH='$2a$14$replace-with-caddy-bcrypt-hash'
# Automatic channel refresh cron (default: every morning at 7:00)
REFRESH_CRON=0 7 * * *
SCHEDULER_TIMEZONE=Europe/Budapest

# AI/Ollama settings are configured in the app Admin > Setup panel.
FETCH_WORKER_CONCURRENCY=1
AI_WORKER_CONCURRENCY=1
STALE_JOB_MINUTES=30
JOB_CLEANUP_DAYS=7

# Whisper service
WHISPER_THREADS=4
WHISPER_LANGUAGE=auto
WHISPER_BATCH_CRON=0 3 * * *
WHISPER_BATCH_LIMIT=50
