# PostgreSQL
POSTGRES_PASSWORD=directus

# Directus
DIRECTUS_SECRET=change-me-in-production-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin
DIRECTUS_ADMIN_TOKEN=admin-token-change-me

# Public URLs (for browser access)
PUBLIC_DIRECTUS_URL=https://yt.suliweb.org/admin
PUBLIC_FETCHER_URL=https://yt.suliweb.org/api
PUBLIC_WHISPER_URL=https://yt.suliweb.org/whisper

# Automatic channel refresh cron (default: daily at 2:00 AM)
REFRESH_CRON=0 2 * * *

# Whisper service
WHISPER_THREADS=4
WHISPER_LANGUAGE=auto
WHISPER_BATCH_CRON=0 3 * * *
WHISPER_BATCH_LIMIT=50
