# PostgreSQL
POSTGRES_PASSWORD=directus
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=directus
POSTGRES_USER=directus

# Directus
DIRECTUS_SECRET=change-me-random-string
DIRECTUS_ADMIN_EMAIL=admin@example.com
DIRECTUS_ADMIN_PASSWORD=admin
DIRECTUS_ADMIN_TOKEN=admin-token-change-me

# Automatic channel refresh cron (default: every morning at 7:00)
REFRESH_CRON=0 7 * * *
SCHEDULER_TIMEZONE=Europe/Budapest

# AI notebook fields (Ollama)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=gemma4:31b
AI_NOTES_AUTO=true
AI_NOTES_BATCH_LIMIT=10
AI_NOTES_MAX_BATCH_LIMIT=20000

# Whisper service
WHISPER_THREADS=4
WHISPER_LANGUAGE=auto
WHISPER_BATCH_CRON=0 3 * * *
WHISPER_BATCH_LIMIT=50
